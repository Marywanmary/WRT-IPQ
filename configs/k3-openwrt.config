# configs/k3-openwrt.config
# 斐讯K3配置文件 (OpenWrt)
CONFIG_TARGET_bcm53xx=y
CONFIG_TARGET_bcm53xx_generic=y
CONFIG_TARGET_bcm53xx_generic_DEVICE_phicomm_k3=y

# 基础软件包
CONFIG_PACKAGE_zram-swap=y
CONFIG_PACKAGE_netspeedtest=y
CONFIG_PACKAGE_tailscale=y
CONFIG_PACKAGE_taskplan=y
CONFIG_PACKAGE_ttyd=y
CONFIG_PACKAGE_upnp=y
CONFIG_PACKAGE_openclash=y

# Lite版本额外软件包
# (无额外软件包)

# Full版本额外软件包
CONFIG_PACKAGE_ddns-go=y
CONFIG_PACKAGE_easytier=y
CONFIG_PACKAGE_homeproxy=y

# LuCI界面
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-app-netspeedtest=y
CONFIG_PACKAGE_luci-app-tailscale=y
CONFIG_PACKAGE_luci-i18n-tailscale-zh-cn=y
CONFIG_PACKAGE_luci-app-taskplan=y
CONFIG_PACKAGE_luci-app-ttyd=y
CONFIG_PACKAGE_luci-app-upnp=y
CONFIG_PACKAGE_luci-app-openclash=y

# Full版本LuCI
CONFIG_PACKAGE_luci-app-ddns-go=y
CONFIG_PACKAGE_luci-app-easytier=y
CONFIG_PACKAGE_luci-app-homeproxy=y
CONFIG_PACKAGE_luci-i18n-homeproxy-zh-cn=y

# 语言包
CONFIG_LUCI_LANG_zh_Hans=y
