# configs/ipq60xx-immortalwrt.config
# 京东云IPQ60XX设备配置文件 (ImmortalWrt)
CONFIG_TARGET_qualcommax=y
CONFIG_TARGET_qualcommax_ipq60xx=y
CONFIG_TARGET_qualcommax_ipq60xx_DEVICE_jdcloud_re-ss-01=y
CONFIG_TARGET_qualcommax_ipq60xx_DEVICE_jdcloud_re-cs-02=y

# 基础软件包
CONFIG_PACKAGE_zram-swap=y
CONFIG_PACKAGE_netspeedtest=y
CONFIG_PACKAGE_tailscale=y
CONFIG_PACKAGE_taskplan=y
CONFIG_PACKAGE_ttyd=y
CONFIG_PACKAGE_upnp=y
CONFIG_PACKAGE_openclash=y

# Lite版本额外软件包
CONFIG_PACKAGE_easytier=m
CONFIG_PACKAGE_homeproxy=m
CONFIG_PACKAGE_lucky=m

# Full版本额外软件包
CONFIG_PACKAGE_ddns-go=m
CONFIG_PACKAGE_istorex=m

# LuCI界面
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-app-netspeedtest=y
CONFIG_PACKAGE_luci-app-tailscale=y
CONFIG_PACKAGE_luci-i18n-tailscale-zh-cn=y
CONFIG_PACKAGE_luci-app-taskplan=y
CONFIG_PACKAGE_luci-app-ttyd=y
CONFIG_PACKAGE_luci-app-upnp=y
CONFIG_PACKAGE_luci-app-openclash=y

# Lite版本LuCI
CONFIG_PACKAGE_luci-app-easytier=m
CONFIG_PACKAGE_luci-app-homeproxy=m
CONFIG_PACKAGE_luci-i18n-homeproxy-zh-cn=m
CONFIG_PACKAGE_luci-app-lucky=m

# Full版本LuCI
CONFIG_PACKAGE_luci-app-ddns-go=m
CONFIG_PACKAGE_luci-app-istorex=m

# 语言包
CONFIG_LUCI_LANG_zh_Hans=y
