# === 基础TARGET配置 ===
CONFIG_TARGET_qualcommax=y
CONFIG_TARGET_qualcommax_ipq60xx=y
CONFIG_TARGET_MULTI_PROFILE=y
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_jdcloud_re-ss-01=y
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_jdcloud_re-cs-02=y
CONFIG_TARGET_DEVICE_PACKAGES_qualcommax_ipq60xx_DEVICE_jdcloud_re-cs-02="luci-app-athena-led luci-i18n-athena-led-zh-cn"

# === 编译优化 ===
CONFIG_DEVEL=y
CONFIG_TARGET_OPTIONS=y
CONFIG_TARGET_OPTIMIZATION="-O3 -pipe -march=armv8-a+crypto+crc -mcpu=cortex-a53+crypto+crc -mtune=cortex-a53"

# === NSS配置 ===
CONFIG_ATH11K_MEM_PROFILE_512M=y
# === Lite对应ImmWrt/OpenWrt的NSS 固件版本12.5===
# CONFIG_NSS_FIRMWARE_VERSION_12_5=y
# === Full对应LibWrt的NSS 固件版本11.4===
CONFIG_NSS_FIRMWARE_VERSION_11_4=y

# === 雅典娜灯光控制 ===
CONFIG_PACKAGE_luci-app-athena-led=m
CONFIG_PACKAGE_luci-i18n-athena-led-zh-cn=m

# ====== laipeng668定制包 ======
#CONFIG_PACKAGE_sqm-scripts-nss=y
#CONFIG_PACKAGE_luci-app-openlist2=y
#CONFIG_PACKAGE_luci-app-wifischedule=y

# ====== Mary定制包Lite======
# ====== Mary定制包Full======
# ====== 可以只添加luci和i18n，依赖原包会自动安装 ======

CONFIG_PACKAGE_luci-app-ddns-go=y
CONFIG_PACKAGE_luci-i18n-ddns-go-zh-cn=y
CONFIG_PACKAGE_luci-app-frpc=y
CONFIG_PACKAGE_luci-app-frps=y
CONFIG_PACKAGE_luci-app-homeproxy=y
CONFIG_PACKAGE_luci-i18n-homeproxy-zh-cn=y
CONFIG_PACKAGE_luci-app-istorex=y
CONFIG_PACKAGE_luci-i18n-istorex-zh-cn=y
CONFIG_PACKAGE_luci-app-openlist2=y
CONFIG_PACKAGE_luci-i18n-openlist2-zh-cn=y
CONFIG_PACKAGE_luci-app-timewol=y
CONFIG_PACKAGE_luci-app-wolplus=y
CONFIG_PACKAGE_luci-app-zerotier=y
CONFIG_PACKAGE_luci-i18n-zerotier-zh-cn=y
